    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.11.0",
    "react-toastify": "^11.0.5",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
